// Mensagens exibidas pela interface do sistema:
//
// 0 = Bem-vindo ao sistema BM32OS
// 1 = Operações: 1-processos, 2-arquivos
// 2 = Quantos arquivos devem ser executados?
// 3 = Este arquivo não existe!
// 4 = Executando processos...
// 5 = Todos os processos terminaram a execução
// 6 = Escolha a operação de arquivo
// 7 = 1 - criar, 2 - renomear, 3 - excluir
// 8 = Não foi possível realizar a operação, o HD está cheio!
// 9 = Digite a quantidade de instruções do arquivo
// 10 = Primeiros 16 bits da instrução
// 11 = Últimos 16 bits da instrução
// 12 = Digite um ID para o novo arquivo
// 13 = O novo ID não pode ser igual a um ID existente!
// 14 = Arquivo criado com sucesso
// 15 = Escolha um arquivo para ser renomeado
// 16 = Escolha um arquivo existente!
// 17 = Escolha o novo ID do arquivo
// 18 = O ID escolhido deve ser único!
// 19 = Arquivo renomeado com sucesso
// 20 = Escolha um arquivo para ser excluído
// 21 = Arquivo excluído com sucesso
// 29 = Digite os IDs dos arquivos
// 30 = O processo necessita de uma entrada
// 31 = O processo necessita realizar uma saída
// 32 = Um processo terminou sua execução
// 33 = Um processo necessita receber dados pela UART
// 34 = Um processo necessita enviar dados pela UART


/**** Valores relacionados ao sistema operacional ****/

// Quantidade máxima de processos suportada pelo sistema.
//
// Esse valor é configurado durante a inicialização do sistema
// e também é utilizado como limite para percorrer os vetores.
int MAX_PROC_NUM;


// Quantidade máxima de arquivos suportada pelo sistema.
//
// Define o tamanho útil das estruturas responsáveis pelo
// armazenamento das informações dos arquivos.
int MAX_FILE_NUM;


// Quantidade atual de arquivos armazenados no HD.
//
// Esse valor é alterado sempre que um arquivo é criado
// ou removido do sistema.
int FILE_AMOUNT;


// Armazena o código da interrupção solicitada pelo processo.
//
// O código é obtido de um registrador especial do processador
// quando o controle retorna do processo para o sistema operacional.
int INTERRUPTION;


// Tamanho da região do HD reservada para cada arquivo.
//
// Essa região determina quantas posições cada arquivo pode
// ocupar dentro do dispositivo de armazenamento.
int HD_REGION;


// Tamanho da região da memória reservada para cada processo.
//
// Cada processo possui uma área própria para armazenar o
// contexto de seus registradores durante uma troca de contexto.
int MEM_REGION;


// Variável utilizada para interromper temporariamente a interface.
//
// A leitura de entrada impede que determinadas mensagens sejam
// substituídas imediatamente, aguardando uma confirmação externa.
int STOP_BASH;


/**** Estruturas de dados dos arquivos ****/

// Armazena os IDs dos arquivos existentes.
//
// Cada posição do vetor representa um arquivo do sistema.
// O valor 99 é utilizado posteriormente para indicar uma
// posição livre na tabela de arquivos.
int file_IDS[15];


// Armazena a posição inicial de cada arquivo no HD.
//
// O índice utilizado neste vetor é o mesmo índice utilizado
// nos vetores file_IDS e file_end.
int file_begin[15];


// Armazena a posição final de cada arquivo no HD.
//
// Com file_begin e file_end, o sistema consegue determinar
// a região do HD ocupada pelas instruções de cada arquivo.
int file_end[15];


/**** Estruturas de dados dos processos ****/

// Armazena o estado de execução de cada processo.
//
// 0 = processo pronto para ser executado.
// 1 = processo que já terminou sua execução.
int proc_state[15];


// Fila de processos utilizada pelo escalonador Round Robin.
//
// O vetor armazena os IDs dos arquivos escolhidos para execução,
// determinando a ordem em que os processos receberão o processador.
int proc_queue[15];


// Armazena o Program Counter de cada processo.
//
// Durante uma troca de contexto, o endereço da próxima instrução
// de cada processo é salvo neste vetor. Dessa forma, quando o
// processo voltar a executar, ele continuará do ponto em que parou.
int proc_PCS[15];


/**** Funções relacionadas aos processos ****/


// Reinicia o Program Counter de todos os processos.
//
// Essa função é chamada depois que um conjunto de processos
// termina sua execução. Assim, os processos poderão começar
// novamente a partir da primeira instrução em uma futura execução.
void reset_program_counters( void ) {
	int idx;

	// A posição zero não é utilizada para armazenar processos.
	// Por isso, a busca começa na posição 1.
	idx = 1;

	// Percorre todas as posições destinadas aos processos.
	while( idx < MAX_PROC_NUM ) {

		// Define o Program Counter do processo como zero,
		// fazendo com que uma nova execução comece do início.
		proc_PCS[ idx ] = 0;

		idx = idx + 1;
	}

	return;
}


// Limpa a fila de processos para futuras execuções.
//
// Depois que o escalonamento termina, todos os valores da fila
// são definidos como zero para que novos processos possam ser
// selecionados sem manter dados da execução anterior.
void reset_process_queue( void ) {
	int idx;

	idx = 0;

	// Percorre todas as posições da fila.
	while( idx < MAX_PROC_NUM ) {

		// Remove o ID anteriormente armazenado na posição.
		proc_queue[ idx ] = 0;

		idx = idx + 1;
	}

	return;
}


// Verifica se um determinado ID de arquivo existe.
//
// Retorna 1 caso o ID seja encontrado na tabela de arquivos.
// Retorna 0 caso o ID não esteja cadastrado.
int check_ID( int ID ) {
	int idx;
	int ret_value;

	// A posição zero da tabela não é utilizada.
	idx = 1;

	// Inicialmente, considera-se que o ID não foi encontrado.
	ret_value = 0;

	// Percorre a tabela procurando pelo ID recebido.
	while( idx < MAX_PROC_NUM ) {

		if( file_IDS[ idx ] == ID ) {

			// O ID foi encontrado.
			ret_value = 1;

			// Força o encerramento do laço, pois não é
			// necessário continuar procurando.
			idx = MAX_PROC_NUM;
		}
		else {

			// Avança para a próxima posição da tabela.
			idx = idx + 1;
		}
	}

	return ret_value;
}


// Obtém o índice correspondente ao ID de um processo.
//
// Os processos são identificados pelo mesmo ID dos arquivos
// executáveis armazenados no sistema. Essa função procura o ID
// na tabela de arquivos e retorna a posição em que ele está salvo.
int get_proc_idx( int proc_ID ) {
	int idx;
	int proc_idx;

	// A posição zero não é utilizada.
	idx = 1;

	// Percorre a tabela de arquivos.
	while( idx < MAX_PROC_NUM ) {

		if( file_IDS[ idx ] == proc_ID ) {

			// Salva o índice correspondente ao processo.
			proc_idx = idx;

			// Encerra o laço depois de encontrar o processo.
			idx = MAX_PROC_NUM;
		}
		else {

			// Continua procurando nas próximas posições.
			idx = idx + 1;
		}
	}

	return proc_idx;
}


// Carrega o contexto de um processo antes de sua execução.
//
// A função realiza duas operações principais:
//
// 1. Transfere as instruções do processo do HD para a memória.
// 2. Recupera os valores dos registradores salvos anteriormente.
//
// Dessa forma, o processo pode continuar sua execução exatamente
// do ponto em que havia sido interrompido.
void load_proc_context( int proc_idx ) {
	int transfer_iterations;
	int transfer_idx;

	// Calcula a quantidade de instruções existentes no arquivo.
	//
	// A diferença entre a posição final e a posição inicial
	// representa a quantidade de posições que precisam ser
	// transferidas do HD para a memória.
	transfer_iterations = file_end[ proc_idx ] - file_begin[ proc_idx ];

	// Inicia a transferência pela primeira instrução.
	transfer_idx = 0;

	// Transfere cada instrução do processo do HD para a memória.
	while( transfer_idx < transfer_iterations ) {

		// Parâmetros:
	 // proc_idx     = índice do processo;
		// transfer_idx = linha do arquivo no HD;
		// transfer_idx = linha de destino na memória.
		//
		// As instruções são carregadas a partir da posição zero
		// da memória de instruções utilizada pelo processador.
		move_HD_mem( proc_idx, transfer_idx, transfer_idx );

		transfer_idx = transfer_idx + 1;
	}

	// Calcula o início da região de memória reservada
	// para armazenar o contexto deste processo.
	//
	// Cada processo possui uma região própria, evitando que os
	// registradores de um processo sobrescrevam os de outro.
	transfer_idx = proc_idx * MEM_REGION;

	// Recupera o valor salvo do registrador 1.
	load_reg_context( 1, transfer_idx, 1 );

	// Recupera o valor salvo do registrador 2.
	load_reg_context( 2, transfer_idx, 2 );

	// Recupera o valor salvo do registrador 3.
	load_reg_context( 3, transfer_idx, 3 );

	// Recupera o valor salvo do registrador 4.
	load_reg_context( 4, transfer_idx, 4 );

	// Recupera o valor salvo do registrador 5.
	load_reg_context( 5, transfer_idx, 5 );

	// Recupera o valor salvo do registrador 6.
	load_reg_context( 6, transfer_idx, 6 );

	// Recupera o valor salvo do registrador 7.
	load_reg_context( 7, transfer_idx, 7 );

	// Recupera o valor salvo do registrador 8.
	load_reg_context( 8, transfer_idx, 8 );

	// Recupera o valor salvo do registrador 9.
	load_reg_context( 9, transfer_idx, 9 );

	// Recupera o valor salvo do registrador 10.
	load_reg_context( 10, transfer_idx, 10 );

	// Recupera o valor salvo do registrador 11.
	load_reg_context( 11, transfer_idx, 11 );

	// Recupera o valor salvo do registrador 12.
	load_reg_context( 12, transfer_idx, 12 );

	// Recupera o valor salvo do registrador 13.
	load_reg_context( 13, transfer_idx, 13 );

	// Recupera o valor salvo do registrador 14.
	load_reg_context( 14, transfer_idx, 14 );

	// Recupera o valor salvo do registrador 15.
	load_reg_context( 15, transfer_idx, 15 );

	// Recupera o valor salvo do registrador 16.
	load_reg_context( 16, transfer_idx, 16 );

	// Recupera o valor salvo do registrador 17.
	load_reg_context( 17, transfer_idx, 17 );

	// Recupera o valor salvo do registrador 18.
	load_reg_context( 18, transfer_idx, 18 );

	// Recupera o valor salvo do registrador 19.
	load_reg_context( 19, transfer_idx, 19 );

	// Recupera o valor salvo do registrador 20.
	load_reg_context( 20, transfer_idx, 20 );

	// Recupera o valor salvo do registrador 21.
	load_reg_context( 21, transfer_idx, 21 );

	// Recupera o valor salvo do registrador 22.
	load_reg_context( 22, transfer_idx, 22 );

	// Recupera o valor salvo do registrador 23.
	load_reg_context( 23, transfer_idx, 23 );

	// Recupera o valor salvo do registrador 24.
	load_reg_context( 24, transfer_idx, 24 );

	// Recupera o valor salvo do registrador 25.
	load_reg_context( 25, transfer_idx, 25 );

	// Recupera o valor salvo do registrador 26.
	load_reg_context( 26, transfer_idx, 26 );

	// Recupera o valor salvo do registrador 27.
	//
	// Neste sistema, esse registrador também é utilizado
	// para a troca de dados de entrada e saída dos processos.
	load_reg_context( 27, transfer_idx, 27 );

	// Recupera o valor salvo do registrador 28.
	//
	// Esse registrador está relacionado ao código de interrupção
	// solicitado pelo processo.
	load_reg_context( 28, transfer_idx, 28 );

	// Recupera o valor salvo do registrador 29.
	load_reg_context( 29, transfer_idx, 29 );

	// Recupera o valor salvo do registrador 30.
	load_reg_context( 30, transfer_idx, 30 );

	// Recupera o valor salvo do registrador 31.
	load_reg_context( 31, transfer_idx, 31 );

	return;
}
// Salva o contexto de um processo.
//
// Essa função é chamada sempre que ocorre uma troca de contexto.
// Todos os registradores do processo são armazenados em uma região
// exclusiva da memória, permitindo que o processo continue sua
// execução futuramente exatamente do ponto em que foi interrompido.
void store_proc_context( int proc_idx ) {
	int transfer_idx;

	// Calcula o início da região de memória reservada para este processo.
	transfer_idx = proc_idx * MEM_REGION;

	// Salva o conteúdo de todos os registradores.
	//
	// Cada chamada copia um registrador do processador para a área
	// de contexto correspondente ao processo.
	store_reg_context( 1, transfer_idx, 1 );
