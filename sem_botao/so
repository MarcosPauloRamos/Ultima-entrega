// Controla o menu principal do sistema operacional.
//
// Essa função funciona como uma interface básica entre o usuário
// e as operações disponíveis no sistema.
//
// As opções são:
//
// 1 = operações relacionadas aos processos;
// 2 = operações relacionadas aos arquivos.
void bash( void ) {
	int bash_option;

	// Exibe as opções principais do sistema.
	write_lcd( 1 );

	// Recebe a opção escolhida pelo usuário.
	bash_option = input( );

	// Exibe o valor recebido para confirmação.
	output( bash_option );

	/**************************************************
	 * Opção 1: operações relacionadas aos processos
	 **************************************************/
	if( bash_option == 1 ) {

		// Permite selecionar arquivos executáveis
		// e iniciar o escalonamento dos processos.
		process_operation( );
	}

	/**************************************************
	 * Opção 2: operações relacionadas aos arquivos
	 **************************************************/
	if( bash_option == 2 ) {

		// Permite criar, renomear ou excluir arquivos.
		file_operation( );
	}

	return;
}


// Inicializa as estruturas e variáveis do sistema operacional.
//
// Essa função configura:
//
// 1. A quantidade máxima de processos;
// 2. A quantidade máxima de arquivos;
// 3. A quantidade inicial de arquivos;
// 4. O tamanho das regiões do HD e da memória;
// 5. Os IDs dos arquivos conhecidos;
// 6. Os Program Counters dos processos;
// 7. As posições inicial e final dos programas no HD.
void init( void ) {
	int idx;

	/**************************************************
	 * Configuração das variáveis do sistema
	 **************************************************/

	// Define a quantidade máxima de processos suportados.
	MAX_PROC_NUM = 15;

	// Define a quantidade máxima de arquivos suportados.
	MAX_FILE_NUM = 15;

	// Define a quantidade inicial de arquivos conhecidos.
	//
	// O sistema considera inicialmente dez posições ocupadas,
	// incluindo a posição zero reservada.
	FILE_AMOUNT = 10;

	// Define o tamanho da região reservada para cada arquivo no HD.
	HD_REGION = 1024;

	// Define o tamanho da região de memória reservada
	// para salvar o contexto de cada processo.
	MEM_REGION = 252;


	/**************************************************
	 * Inicialização da tabela de arquivos
	 **************************************************/

	// A posição zero é reservada, por isso o índice começa em 1.
	idx = 1;

	// Percorre todas as posições destinadas aos arquivos.
	while( idx < MAX_PROC_NUM ) {

		if( idx < 10 ) {

			// Os índices de 1 até 9 correspondem aos
			// arquivos já conhecidos pelo sistema.
			//
			// O ID do arquivo é igual ao próprio índice.
			file_IDS[ idx ] = idx;
		}
		else {

			// Os índices de 10 até 14 começam livres.
			//
			// O valor 99 indica que não existe um
			// arquivo cadastrado nessa posição.
			file_IDS[ idx ] = 99;
		}

		// Reinicia o Program Counter de cada processo.
		//
		// Dessa forma, todos os processos começam sua
		// primeira execução a partir da instrução zero.
		proc_PCS[ idx ] = 0;

		idx = idx + 1;
	}


	/**************************************************
	 * Configuração das posições dos arquivos no HD
	 **************************************************/

	// Inicializa a posição zero da tabela.
	//
	// Essa posição não representa um programa executável,
	// mas é configurada para evitar valores indefinidos.
	file_begin[ 0 ] = 0;
	file_end[ 0 ] = 0;


	// Programa 1: cálculo de potência.
	//
	// O arquivo começa na posição zero de sua região no HD
	// e possui instruções até a posição 51.
	file_begin[ 1 ] = 0;
	file_end[ 1 ] = 51;


	// Programa 2: cálculo da sequência de Fibonacci.
	//
	// O arquivo possui instruções até a posição 68.
	file_begin[ 2 ] = 0;
	file_end[ 2 ] = 68;


	// Programa 3: busca do maior valor.
	//
	// O arquivo possui instruções até a posição 75.
	file_begin[ 3 ] = 0;
	file_end[ 3 ] = 75;


	// Programa 4: busca do menor valor.
	//
	// O arquivo possui instruções até a posição 76.
	file_begin[ 4 ] = 0;
	file_end[ 4 ] = 76;


	// Programa 5: algoritmo Selection Sort.
	//
	// O arquivo possui instruções até a posição 154.
	file_begin[ 5 ] = 0;
	file_end[ 5 ] = 154;


	// Programa 6: cálculo da média de um vetor.
	//
	// O arquivo possui instruções até a posição 72.
	file_begin[ 6 ] = 0;
	file_end[ 6 ] = 72;


	// Programa 7: posição reservada.
	//
	// Como ainda não existem instruções cadastradas,
	// as posições inicial e final permanecem em zero.
	file_begin[ 7 ] = 0;
	file_end[ 7 ] = 0;


	// Programa 8: posição reservada.
	file_begin[ 8 ] = 0;
	file_end[ 8 ] = 0;


	// Programa 9: posição reservada.
	file_begin[ 9 ] = 0;
	file_end[ 9 ] = 0;

	return;
}


// Função principal do sistema operacional.
//
// Essa é a primeira função executada. Ela inicializa o sistema,
// exibe a mensagem de boas-vindas e mantém o menu principal
// funcionando continuamente.
void main( void ) {

	// Inicializa todas as estruturas do sistema operacional.
	init( );

	// Exibe a mensagem de boas-vindas.
	write_lcd( 0 );

	// Aguarda uma confirmação antes de abrir o menu principal.
	STOP_BASH = input( );

	// Mantém o sistema operacional em execução contínua.
	//
	// Como MAX_PROC_NUM é igual a 15, a condição 1 < MAX_PROC_NUM
	// será sempre verdadeira. Portanto, esse laço funciona como
	// um laço infinito.
	while( 1 < MAX_PROC_NUM ) {

		// Exibe e processa o menu principal do sistema.
		bash( );
	}

	// Em condições normais, este retorno nunca será alcançado,
	// pois o laço anterior mantém o sistema em funcionamento.
	return;
}


