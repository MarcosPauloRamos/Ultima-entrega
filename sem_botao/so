// Escalonador Round Robin.
//
// Percorre continuamente a fila de processos, concedendo um
// intervalo de execução para cada processo ativo.
//
// Quando ocorre uma interrupção, o controle retorna ao sistema
// operacional, que realiza a ação necessária e então agenda o
// próximo processo da fila.
void round_robin( int proc_amount ) {
	int proc_ID;
	int finished_procs;
	int queue_idx;
	int proc_idx;
	int io_var;
	int proc_pc;

	// Nenhum processo terminou inicialmente.
	finished_procs = 0;

	// A execução começa pelo primeiro processo da fila.
	queue_idx = 0;

	// Todos os processos iniciam no endereço zero.
	proc_pc = 0;

	// Informa ao usuário que os processos começaram.
	write_lcd( 4 );

	// Aguarda confirmação antes de iniciar.
	STOP_BASH = input( );

	// Continua executando enquanto ainda existir processo ativo.
	while( finished_procs < proc_amount ) {

		// Obtém o ID do próximo processo da fila.
		proc_ID = proc_queue[ queue_idx ];

		// Localiza esse processo na tabela.
		proc_idx = get_proc_idx( proc_ID );

		// Executa apenas processos que ainda não finalizaram.
		if( proc_state[ proc_idx ] == 0 ) {

			// Recupera o Program Counter salvo anteriormente.
			proc_pc = proc_PCS[ proc_idx ];

			// Configura o PC do processador.
			set_proc_pc( proc_pc );

			// Carrega memória e registradores do processo.
			load_proc_context( proc_idx );

			// Entrega o controle ao processo.
			swap_process( proc_idx );

			// Quando ocorre uma interrupção, o sistema operacional
			// volta automaticamente a assumir o controle.
			recover_OS( );

			// Lê o código da interrupção gerado pelo processo.
			INTERRUPTION = get_interruption( );

			// Salva o novo Program Counter do processo.
			proc_PCS[ proc_idx ] = get_proc_pc( );

			/**************************************************
			 * Interrupção de Entrada
			 **************************************************/
			if( INTERRUPTION == 2 ) {

				// Solicita um dado ao usuário.
				write_lcd( 30 );

				io_var = input( );

				output( io_var );

				// Copia o dado para o registrador 27 do processo.
				move_reg_OS_proc( io_var, 27 );
			}

			/**************************************************
			 * Interrupção de Saída
			 **************************************************/
			if( INTERRUPTION == 3 ) {

				write_lcd( 31 );

				// Copia o valor produzido pelo processo para o SO.
				move_reg_proc_OS( 27, io_var );

				output( io_var );
			}

			/**************************************************
			 * Processo finalizado
			 **************************************************/
			if( INTERRUPTION == 4 ) {

				write_lcd( 32 );

				output( proc_idx );

				// Marca o processo como encerrado.
				proc_state[ proc_idx ] = 1;

				// Atualiza a quantidade de processos concluídos.
				finished_procs = finished_procs + 1;
			}

			/**************************************************
			 * Recepção pela UART
			 **************************************************/
			if( INTERRUPTION == 5 ) {

				write_lcd( 33 );

				// Recebe um dado da UART.
				io_var = UART_input( );

				output( io_var );

				// Disponibiliza o dado ao processo.
				move_reg_OS_proc( io_var, 27 );
			}

			/**************************************************
			 * Transmissão pela UART
			 **************************************************/
			if( INTERRUPTION == 6 ) {

				write_lcd( 34 );

				// Obtém o dado produzido pelo processo.
				move_reg_proc_OS( 27, io_var );

				// Envia o dado pela UART.
				UART_output( io_var );
			}

			// Salva novamente todo o contexto do processo,
			// permitindo que ele continue depois.
			store_proc_context( proc_idx );
		}

		// Avança para o próximo processo da fila.
		//
		// Quando chega ao final, retorna ao início,
		// caracterizando o comportamento circular do
		// algoritmo Round Robin.
		if( queue_idx < proc_amount - 1 ) {
			queue_idx = queue_idx + 1;
		}
		else {
			queue_idx = 0;
		}
	}

	// Todos os processos terminaram.
	write_lcd( 5 );

	STOP_BASH = input( );

	return;
}


// Configura uma nova execução de processos.
//
// Essa função solicita ao usuário quais arquivos deverão ser
// executados e monta a fila utilizada pelo escalonador.
void process_operation( void ) {
	int proc_amount;
	int queue_idx;
	int proc_ID;

	// Pergunta quantos processos serão executados.
	write_lcd( 2 );

	proc_amount = input( );

	output( proc_amount );

	queue_idx = 0;

	// Solicita os IDs dos arquivos.
	write_lcd( 29 );

	while( queue_idx < proc_amount ) {

		proc_ID = input( );

		// Continua solicitando enquanto o ID não existir.
		while( check_ID( proc_ID ) != 1 ) {

			write_lcd( 3 );

			proc_ID = input( );
		}

		output( proc_ID );

		// Insere o processo na fila de execução.
		proc_queue[ queue_idx ] = proc_ID;

		// Marca o processo como apto para execução.
		proc_state[ queue_idx ] = 0;

		queue_idx = queue_idx + 1;
	}

	// Inicia o escalonamento.
	round_robin( proc_amount );

	// Limpa as estruturas para uma próxima execução.
	reset_process_queue( );
	reset_program_counters( );

	return;
}


/*****************************************************
 * Funções relacionadas aos arquivos
 ****************************************************/


// Retorna a próxima posição livre da tabela de arquivos.
//
// O valor 99 representa uma posição disponível.
int get_free_file_position( void ) {
	int idx;
	int ret_idx;

	idx = 1;

	ret_idx = 0;

	while( idx < MAX_FILE_NUM ) {

		if( file_IDS[ idx ] == 99 ) {

			ret_idx = idx;

			idx = MAX_FILE_NUM;
		}
		else {

			idx = idx + 1;
		}
	}

	return ret_idx;
}
// Cria um novo arquivo no HD.
//
// A função recebe o índice livre da tabela de arquivos.
// Depois, solicita ao usuário:
//
// 1. A quantidade de instruções do arquivo;
// 2. Os primeiros 16 bits de cada instrução;
// 3. Os últimos 16 bits de cada instrução;
// 4. Um ID único para identificar o arquivo.
void create_file( int file_idx ) {
	int file_ID;
	int file_instructions;
	int idx;
	int first_bits;
	int last_bits;
	int instruction;

	// Solicita a quantidade de instruções que o novo arquivo terá.
	write_lcd( 9 );

	file_instructions = input( );

	// Exibe o valor recebido para confirmação.
	output( file_instructions );

	// Inicia o índice da primeira instrução.
	idx = 0;

	// Recebe e armazena todas as instruções do arquivo.
	while( idx < file_instructions ) {

		// Solicita os primeiros 16 bits da instrução.
		write_lcd( 10 );

		first_bits = input( );

		// Solicita os últimos 16 bits da instrução.
		write_lcd( 11 );

		last_bits = input( );

		// Junta as duas partes de 16 bits para formar
		// uma instrução completa de 32 bits.
		instruction = concatenate( first_bits, last_bits );

		// Armazena a instrução no HD.
		//
		// Parâmetros:
		// file_idx = índice do arquivo;
		// idx      = posição da instrução dentro do arquivo;
		// instruction = instrução completa de 32 bits.
		store_HD( file_idx, idx, instruction );

		// Avança para a próxima instrução.
		idx = idx + 1;
	}

	// Depois de armazenar todas as instruções,
	// solicita um ID para o novo arquivo.
	write_lcd( 12 );

	file_ID = input( );

	output( file_ID );

	// Verifica se o ID escolhido já pertence a outro arquivo.
	//
	// O sistema continua solicitando um novo ID enquanto
	// o usuário escolher um valor que já está em uso.
	while( check_ID( file_ID ) == 1 ) {

		write_lcd( 13 );

		file_ID = input( );
	}

	// Armazena o ID escolhido na tabela de arquivos.
	file_IDS[ file_idx ] = file_ID;

	// Define a posição inicial do arquivo.
	//
	// Como cada arquivo possui uma região própria no HD,
	// suas instruções começam na posição zero dessa região.
	file_begin[ file_idx ] = 0;

	// Define a posição final do arquivo com base na
	// quantidade de instruções armazenadas.
	file_end[ file_idx ] = file_instructions;

	// Informa que o arquivo foi criado com sucesso.
	write_lcd( 14 );

	// Aguarda uma confirmação antes de retornar ao menu.
	STOP_BASH = input( );

	return;
}


// Renomeia um arquivo existente.
//
// O usuário informa o ID atual do arquivo e, depois,
// escolhe um novo ID que ainda não esteja sendo utilizado.
void rename_file( void ) {
	int idx;
	int file_ID;
	int new_ID;

	// Solicita o ID do arquivo que será renomeado.
	write_lcd( 15 );

	file_ID = input( );

	output( file_ID );

	// Verifica se o arquivo informado realmente existe.
	//
	// Enquanto o ID não for encontrado, o sistema solicita
	// novamente um arquivo válido.
	while( check_ID( file_ID ) != 1 ) {

		write_lcd( 16 );

		file_ID = input( );
	}

	// Solicita o novo ID do arquivo.
	write_lcd( 17 );

	new_ID = input( );

	output( new_ID );

	// O novo ID precisa ser único.
	//
	// Caso o ID já pertença a outro arquivo, o usuário
	// deverá informar um valor diferente.
	while( check_ID( new_ID ) == 1 ) {

		write_lcd( 18 );

		new_ID = input( );
	}

	// A busca começa na posição 1, pois a posição zero
	// não é utilizada para armazenar arquivos executáveis.
	idx = 1;

	// Procura o arquivo na tabela de IDs.
	while( idx < MAX_PROC_NUM ) {

		if( file_IDS[ idx ] == file_ID ) {

			// Substitui o ID antigo pelo novo ID.
			//
			// Apenas o nome identificador é alterado.
			// As instruções armazenadas no HD permanecem iguais.
			file_IDS[ idx ] = new_ID;

			// Encerra a busca após encontrar o arquivo.
			idx = MAX_PROC_NUM;
		}
		else {

			// Continua procurando nas próximas posições.
			idx = idx + 1;
		}
	}

	// Informa que o arquivo foi renomeado com sucesso.
	write_lcd( 19 );

	// Aguarda uma confirmação antes de retornar.
	STOP_BASH = input( );

	return;
}


// Exclui um arquivo do sistema.
//
// A exclusão remove as referências do arquivo na tabela.
// O ID recebe o valor 99, indicando que a posição está livre.
void delete_file( void ) {
	int idx;
	int file_ID;

	// Solicita o ID do arquivo que será excluído.
	write_lcd( 20 );

	file_ID = input( );

	output( file_ID );

	// Verifica se o arquivo informado existe.
	//
	// Enquanto o ID não for encontrado, o sistema
	// solicita um arquivo válido.
	while( check_ID( file_ID ) != 1 ) {

		write_lcd( 16 );

		file_ID = input( );
	}

	// Inicia a busca na primeira posição utilizada.
	idx = 1;

	// Procura o arquivo na tabela de IDs.
	while( idx < MAX_PROC_NUM ) {

		if( file_IDS[ idx ] == file_ID ) {

			// Remove as referências do arquivo no sistema.
			//
			// O valor 99 indica que essa posição da tabela
			// está disponível para armazenar um novo arquivo.
			file_IDS[ idx ] = 99;

			// Reinicia as posições inicial e final do arquivo.
			//
			// Nesta implementação, os dados não são apagados
			// diretamente do HD. As referências são removidas,
			// permitindo que essa região seja reutilizada.
			file_begin[ idx ] = 0;
			file_end[ idx ] = 0;

			// Encerra a busca após encontrar o arquivo.
			idx = MAX_PROC_NUM;
		}
		else {

			// Continua procurando nas próximas posições.
			idx = idx + 1;
		}
	}

	// Informa que o arquivo foi excluído com sucesso.
	write_lcd( 21 );

	// Aguarda uma confirmação antes de retornar ao menu.
	STOP_BASH = input( );

	return;
}


// Controla as operações relacionadas aos arquivos.
//
// O usuário pode escolher entre:
//
// 1 = criar um arquivo;
// 2 = renomear um arquivo;
// 3 = excluir um arquivo.
void file_operation( void ) {
	int file_idx;
	int file_ID;
	int file_position;
	int file_option;

	// Exibe a mensagem de escolha da operação de arquivo.
	write_lcd( 6 );

	// Aguarda uma confirmação antes de apresentar as opções.
	STOP_BASH = input( );

	// Exibe as opções disponíveis.
	write_lcd( 7 );

	file_option = input( );

	output( file_option );

	/**************************************************
	 * Opção 1: criar um novo arquivo
	 **************************************************/
	if( file_option == 1 ) {

		// Verifica se a quantidade atual de arquivos
		// atingiu o limite máximo suportado.
		if( MAX_FILE_NUM == FILE_AMOUNT ) {

			// Informa que não existem posições livres no HD.
			write_lcd( 8 );

			STOP_BASH = input( );
		}
		else {

			// Procura a próxima posição livre
			// na tabela de arquivos.
			file_idx = get_free_file_position( );

			// Cria o arquivo na posição encontrada.
			create_file( file_idx );

			// Atualiza a quantidade total de arquivos.
			FILE_AMOUNT = FILE_AMOUNT + 1;
		}
	}

	/**************************************************
	 * Opção 2: renomear um arquivo
	 **************************************************/
	if( file_option == 2 ) {

		rename_file( );
	}

	/**************************************************
	 * Opção 3: excluir um arquivo
	 **************************************************/
	if( file_option == 3 ) {

		delete_file( );

		// Atualiza a quantidade total de arquivos.
		FILE_AMOUNT = FILE_AMOUNT - 1;
	}

	return;
}
